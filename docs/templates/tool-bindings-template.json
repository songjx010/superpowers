{
  "_comment": "Copy this file to your project root as tool-bindings.json and fill in enterprise MCP details.",
  "version": 1,
  "mcp_servers": {
    "your_ci_server": {
      "_comment": "Enterprise CI/CD MCP server — provides test, coverage, mutation capabilities",
      "command": "npx",
      "args": ["-y", "@your-org/ci-mcp@latest"]
    },
    "your_browser_server": {
      "_comment": "Enterprise browser automation MCP server — replaces Chrome DevTools MCP",
      "command": "npx",
      "args": ["-y", "@your-org/browser-mcp@latest"],
      "availability_probe": "your_browser_server__ping"
    }
  },
  "capability_bindings": {
    "test": {
      "_comment": "Maps to the 'test' capability — runs tests for a feature",
      "type": "mcp",
      "tool": "your_ci_server__run_tests",
      "input_template": {
        "project_path": ".",
        "feature_id": "{{feature_id}}"
      },
      "result_fields": {
        "all_passed": "$.results.all_passed",
        "summary": "$.results.summary"
      }
    },
    "coverage": {
      "_comment": "Maps to the 'coverage' capability — measures code coverage",
      "type": "mcp",
      "tool": "your_ci_server__coverage",
      "input_template": {
        "project_path": ".",
        "line_threshold": "{{quality_gates.line_coverage_min}}",
        "branch_threshold": "{{quality_gates.branch_coverage_min}}"
      },
      "result_fields": {
        "line_pct": "$.coverage.line_pct",
        "branch_pct": "$.coverage.branch_pct",
        "passed": "$.coverage.threshold_met"
      }
    },
    "mutation": {
      "_comment": "Maps to the 'mutation' capability — runs mutation testing",
      "type": "mcp",
      "tool": "your_ci_server__mutation",
      "input_template": {
        "project_path": ".",
        "scope": "{{changed_files}}",
        "min_score": "{{quality_gates.mutation_score_min}}"
      },
      "result_fields": {
        "score": "$.mutation.score",
        "passed": "$.mutation.threshold_met"
      }
    },
    "ui_tools": {
      "_comment": "Maps Chrome DevTools MCP tool names to enterprise browser automation tool names",
      "type": "mcp",
      "tool_mapping": {
        "navigate_page":         "your_browser_server__navigate",
        "wait_for":              "your_browser_server__wait",
        "take_snapshot":         "your_browser_server__snapshot",
        "take_screenshot":       "your_browser_server__screenshot",
        "click":                 "your_browser_server__click",
        "fill":                  "your_browser_server__fill",
        "press_key":             "your_browser_server__key",
        "evaluate_script":       "your_browser_server__eval",
        "list_console_messages": "your_browser_server__console",
        "hover":                 "your_browser_server__hover",
        "drag":                  "your_browser_server__drag",
        "list_network_requests": "your_browser_server__network"
      }
    }
  }
}
